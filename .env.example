# Copy this file to .env and fill in values for your Pi setup.
# docker compose automatically loads .env from the project root.

# Absolute path to the hailo_platform Python package on the Pi host.
# Find it with: find /usr /home -path "*/hailo_platform/_pyhailort*.so" 2>/dev/null
HAILO_PLATFORM_PATH=/home/myai/.local/lib/python3.13/site-packages/hailo_platform

# Timezone for containers that need it (optional)
# TZ=Europe/Berlin
