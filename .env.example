# Copy this file to .env and fill in values for your Pi setup.
# docker compose automatically loads .env from the project root.

# Absolute path to your Home Assistant config directory on the Pi host.
HA_CONFIG_DIR=/opt/homeassistant/config

# Long-lived HA access token — only needed when WHISPER_RAW_LOG is enabled
# in hailo-whisper. Generate at: http://<ha-ip>:8123/profile/security
HA_ACCESS_TOKEN=

# Timezone for the piper TTS container (default: America/Los_Angeles)
# TZ=Europe/Berlin
